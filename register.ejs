<!DOCTYPE html>
<html>

<head>
    <title>Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-5" style="max-width:500px">
        <h1>Register</h1>
        <% if (messages.length) { %>
            <div class="alert alert-danger">
                <%= messages[0] %>
            </div>
            <% } %>
                <form action="/register" method="POST">
                    <div class="mb-3"><label>Username</label><input class="form-control" name="username"
                            value="<%= formData.username || '' %>" required></div>
                    <div class="mb-3"><label>Email</label><input class="form-control" type="email" name="email"
                            value="<%= formData.email || '' %>" required></div>
                    <div class="mb-3"><label>Password</label><input class="form-control" type="password" name="password"
                            required></div>
                    <div class="mb-3"><label>Contact</label><input class="form-control" name="contact"
                            value="<%= formData.contact || '' %>"></div><button
                        class="btn btn-primary">Register</button> <a href="/login">Login</a>
                </form>
    </div>
</body>

</html>