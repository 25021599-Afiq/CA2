<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= comic.title %> | Panel Library
    </title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <header class="site-header"><a class="brand" href="/comics">Panel Library</a>
        <div>Signed in as <strong>
                <%= user.username %>
            </strong></div>
    </header>
    <main class="container detail">
        <a class="back-link" href="/comics">← Back to catalogue</a>
        <p class="eyebrow">
            <%= comic.series %>
        </p>
        <h1>
            <%= comic.title %>
        </h1>
        <p class="series">Issue #<%= comic.issue_number %> · <%= comic.publisher %> · <%= comic.published_year %>
        </p>
        <section class="availability-panel">
            <span class="status <%= comic.quantity_available > 0 ? 'available' : 'unavailable' %>">
                <%= comic.availability %>
            </span>
            <strong>
                <%= comic.quantity_available %>
            </strong> of <%= comic.quantity_total %> copies are currently available.
        </section>

        <section>
            <h2>Current borrowing records</h2>
            <% if (activeLoans.length===0) { %>
                <p>No active loans for this comic.</p>
                <% } else { %>
                    <table>
                        <thead>
                            <tr>
                                <th>Borrower</th>
                                <th>Borrowed</th>
                                <th>Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% activeLoans.forEach(loan=> { %><tr>
                                    <td>
                                        <%= loan.username %>
                                    </td>
                                    <td>
                                        <%= new Date(loan.borrowed_at).toLocaleDateString() %>
                                    </td>
                                    <td>
                                        <%= new Date(loan.due_at).toLocaleDateString() %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <% } %>
        </section>
    </main>
</body>

</html>