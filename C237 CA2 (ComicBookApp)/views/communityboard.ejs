<%- include('partials/head') %>

<body>
  <%- include('partials/navbar') %>

  <main class="container my-5">
    <!-- Header Section -->
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom border-secondary pb-3">
      <div>
        <h2 class="fw-bold m-0 text-light">Hive Mind</h2>
        <p class="text-muted m-0">Recent collective thoughts and feedback from the community</p>
      </div>
      <span class="badge bg-warning text-dark fs-6 px-3 py-2">
        <%= feedbackList.length %> <%= feedbackList.length === 1 ? 'Thought' : 'Thoughts' %> Shared
      </span>
    </div>

    <!-- Empty State -->
    <% if (feedbackList.length === 0) { %>
      <div class="text-center py-5 my-5 bg-dark rounded border border-secondary">
        <i class="bi bi-cpu text-muted display-4"></i>
        <h4 class="mt-3 text-muted">The Hive Mind is quiet...</h4>
        <p class="text-secondary">Be the first to transmit your thoughts!</p>
        <a href="/feedback" class="btn btn-warning btn-sm mt-2">Submit Feedback</a>
      </div>
    <% } else { %>

      <!-- Cards Grid -->
      <div class="row g-4">
        <% feedbackList.forEach(fb => { %>
          <div class="col-12 col-md-6 col-lg-4">
            <div class="card bg-dark border-secondary h-100 shadow-sm">
              
              <!-- Card Header with Category Badge & Date -->
              <div class="card-header bg-transparent border-secondary d-flex justify-content-between align-items-center pt-3">
                
                <!-- Category Badges -->
                <% 
                  let badgeClass = 'bg-secondary';
                  const cat = (fb.category || '').toLowerCase();
                  if (cat.includes('inventory') || cat.includes('stock') || cat.includes('book')) badgeClass = 'bg-info text-dark';
                  else if (cat.includes('interface') || cat.includes('improvement')) badgeClass = 'bg-danger';
                  else if (cat.includes('general')) badgeClass = 'bg-primary';
                %>
                <span class="badge <%= badgeClass %> text-capitalize fw-semibold">
                  <%= fb.category %>
                </span>

                <!-- Date Formatting -->
                <small class="text-muted" style="font-size: 0.8rem;">
                  <%= new Date(fb.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </small>
              </div>

              <!-- Card Body / Text -->
              <div class="card-body">
                <p class="card-text text-light" style="white-space: pre-line; line-height: 1.6;">
                  <%= fb.comments %>
                </p>
              </div>

            </div>
          </div>
        <% }) %>
      </div>

    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>