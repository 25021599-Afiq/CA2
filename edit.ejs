<!DOCTYPE html>
<html>

<head>
    <title>Edit Comic</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-5" style="max-width:600px"><a href="/comics">← Back</a>
        <h1>Edit Comic</h1>
        <form action="/editComic/<%= comic.ComicId %>" method="POST">
            <div class="mb-3"><label>Title</label><input class="form-control" name="title" value="<%= comic.Title %>"
                    required></div>
            <div class="mb-3"><label>Series</label><input class="form-control" name="series"
                    value="<%= comic.Series || '' %>"></div>
            <div class="mb-3"><label>Issue Number</label><input class="form-control" type="number" name="issueNo"
                    value="<%= comic.IssueNo %>" required></div>
            <div class="mb-3"><label>Publisher</label><input class="form-control" name="publisher"
                    value="<%= comic.Publisher || '' %>"></div>
            <div class="mb-3"><label>Published Year</label><input class="form-control" type="number"
                    name="publishedYear" value="<%= comic.PublishedYear || '' %>"></div>
            <div class="mb-3"><label>Available Quantity</label><input class="form-control" type="number" name="quantity"
                    min="0" value="<%= comic.Quantity %>" required></div><button class="btn btn-warning">Update
                Comic</button>
        </form>
    </div>
</body>

</html>