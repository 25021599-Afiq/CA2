<!DOCTYPE html>
<html>

<head>
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-5" style="max-width:500px">
        <h1>Login</h1>
        <% if (errors.length) { %>
            <div class="alert alert-danger">
                <%= errors[0] %>
            </div>
            <% } %>
                <% if (messages.length) { %>
                    <div class="alert alert-success">
                        <%= messages[0] %>
                    </div>
                    <% } %>
                        <form action="/login" method="POST">
                            <div class="mb-3"><label>Email</label><input class="form-control" type="email" name="email"
                                    required></div>
                            <div class="mb-3"><label>Password</label><input class="form-control" type="password"
                                    name="password" required></div><button class="btn btn-primary">Login</button> <a
                                href="/register">Register</a>
                        </form>
    </div>
</body>

</html>