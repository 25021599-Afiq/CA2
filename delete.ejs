<!DOCTYPE html>
<html>

<head>
    <title>Delete Comic</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-5">
        <h1>Delete Comic</h1>
        <p>Are you sure you want to delete <strong>
                <%= comic.Title %>
            </strong>?</p>
        <form action="/deleteComic/<%= comic.ComicId %>" method="POST"><button class="btn btn-danger">Yes,
                Delete</button> <a class="btn btn-secondary" href="/comics">Cancel</a></form>
    </div>
</body>

</html>