<!DOCTYPE html>
<html>

<head>
    <title>Add Comic</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-5" style="max-width:600px"><a href="/comics">← Back</a>
        <h1>Add Comic</h1>
        <form action="/addComic" method="POST" enctype="multipart/form-data">
            <div class="mb-3"><label>Comic ID</label><input class="form-control" name="comicId" required></div>
            <div class="mb-3"><label>Title</label><input class="form-control" name="title" required></div>
            <div class="mb-3"><label>Series</label><input class="form-control" name="series"></div>
            <div class="mb-3"><label>Issue Number</label><input class="form-control" type="number" name="issueNo"
                    required></div>
            <div class="mb-3"><label>Publisher</label><input class="form-control" name="publisher"></div>
            <div class="mb-3"><label>Published Year</label><input class="form-control" type="number"
                    name="publishedYear"></div>
            <div class="mb-3"><label>Available Quantity</label><input class="form-control" type="number" name="quantity"
                    min="0" value="1" required></div>
                    
                    <button class="btn btn-primary">Add Comic</button>
        </form>
    </div>
</body>

</html>