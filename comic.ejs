<!DOCTYPE html>
<html>

<head>
    <title>
        <%= comic.Title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-5"><a href="/comics">← Back to catalogue</a>
        <h1>
            <%= comic.Title %>
        </h1>
        <table class="table">
            <tr>
                <th>Comic ID</th>
                <td>
                    <%= comic.ComicId %>
                </td>
            </tr>
            <tr>
                <th>Series</th>
                <td>
                    <%= comic.Series || '-' %>
                </td>
            </tr>
            <tr>
                <th>Issue Number</th>
                <td>
                    <%= comic.IssueNo %>
                </td>
            </tr>
            <tr>
                <th>Publisher</th>
                <td>
                    <%= comic.Publisher || '-' %>
                </td>
            </tr>
            <tr>
                <th>Published Year</th>
                <td>
                    <%= comic.PublishedYear || '-' %>
                </td>
            </tr>
            <tr>
                <th>Available Quantity</th>
                <td>
                    <%= comic.Quantity %>
                </td>
            </tr>
        </table>
    </div>
</body>

</html>