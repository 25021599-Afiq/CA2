<!DOCTYPE html>
<html>

<head>
    <title>Borrow Comic</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-5"><a href="/comics">← Back to comics</a>
        <h1>Borrow a Comic</h1>
        <% if (errors.length) { %>
            <div class="alert alert-danger">
                <%= errors[0] %>
            </div>
            <% } %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Issue</th>
                            <th>Available</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% comics.forEach(comic=> { %><tr>
                                <td>
                                    <%= comic.Title %>
                                </td>
                                <td>
                                    <%= comic.IssueNo %>
                                </td>
                                <td>
                                    <%= comic.Quantity %>
                                </td>
                                <td>
                                    <form action="/booking/<%= comic.ComicId %>" method="POST" class="d-flex gap-2">
                                        <input class="form-control" style="width:80px" type="number" name="quantity"
                                            min="1" max="<%= comic.Quantity %>" value="1"><button
                                            class="btn btn-primary">Borrow</button></form>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
    </div>
</body>

</html>