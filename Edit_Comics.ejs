<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Comics App - Update Comic</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body class="bg-light">

//Navbar
  <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Comics App</a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/inventory">Inventory</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

//Update Form
  <div class="container mt-5">

    <div class="row justify-content-center">

      <div class="col-md-6">

        <% if (comic) { %>

          <div class="card shadow">

            <div class="card-header bg-secondary text-white">
              <h3 class="mb-0">Update Comic</h3>
            </div>

            <div class="card-body">

              <!-- Added enctype="multipart/form-data" for file handling -->
              <form action="/updateComic/<%= comic.productId %>" method="POST" enctype="multipart/form-data">

                <div class="mb-3">
                  <label for="name" class="form-label">
                    Comic Name
                  </label>
                  <input type="text" class="form-control" id="name" name="name" value="<%= comic.comicName %>" required>
                </div>

                <div class="mb-3">
                  <label for="quantity" class="form-label">
                    Quantity
                  </label>
                  <input type="number" class="form-control" id="quantity" name="quantity" min="0" step="1" value="<%= comic.quantity %>" required>
                </div>

                <div class="mb-3">
                  <label for="title" class="form-label">
                    Title
                  </label>
                  <input type="text" class="form-control" id="title" name="title" value="<%= comic.title %>" required>
                </div>

                <div class="mb-3">
                  <label class="form-label">
                    Current Image
                  </label>

                  <div class="text-center">
                    <input type="text" class="form-control mb-2" name="currentImage" value="<%= comic.image %>" readonly><br>
                    <% if (comic.image) { %>
                      <img src="/images/<%= comic.image %>" width="30%" class="img-thumbnail"><br><br>
                    <% } else { %>
                      <p class="text-muted">No image uploaded</p>
                    <% } %>

                    <div class="text-start">
                      <label for="image" class="form-label font-weight-bold">Upload New Image</label>
                      <input type="file" class="form-control" id="image" name="image" accept="image/*">
                    </div>
                  </div>
                </div>

                <div class="d-grid gap-2">
                  <button type="submit" class="btn btn-warning">
                    Update Comic
                  </button>

                  <a href="/inventory" class="btn btn-secondary">
                    Cancel
                  </a>
                </div>

              </form>

            </div>

          </div>

          <% } else { %>

            <div class="alert alert-warning text-center">
              <h5>No comic found.</h5>
              <a href="/inventory" class="btn btn-secondary mt-3">
                Back to Inventory
              </a>
            </div>

            <% } %>

      </div>

    </div>

  </div>

</body>