<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Comics App</title>
</head>

<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid"><a class="navbar-brand" href="/comics">Comics App</a>
            <div class="navbar-nav ms-auto"><a class="nav-link" href="/comics">Comics</a><a class="nav-link"
                    href="/bookingComic">Borrow</a>
                <% if (user.IsAdmin) { %><a class="nav-link" href="/addComic">Add Comic</a>
                    <% } %><a class="nav-link" href="/logout">Logout</a>
            </div>
        </div>
    </nav>
    <main class="container mt-4">
        <h1>Comic Catalogue</h1>
        <% if (messages.length) { %>
            <div class="alert alert-success">
                <%= messages[0] %>
            </div>
            <% } %>
                <% if (errors.length) { %>
                    <div class="alert alert-danger">
                        <%= errors[0] %>
                    </div>
                    <% } %>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Title</th>
                                    <th>Series</th>
                                    <th>Issue</th>
                                    <th>Publisher</th>
                                    <th>Year</th>
                                    <th>Available</th>
                                    <th>Product Image</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% comics.forEach(comic=> { %><tr>
                                        <td>
                                            <%= comic.ComicId %>
                                        </td>
                                        <td><a href="/comic/<%= comic.ComicId %>">
                                                <%= comic.Title %>
                                            </a>
                                        </td>
                                        <td><img src = "images/<%= products[i].image %>" ></td>
                                        <td>
                                            <%= comic.Series || '-' %>
                                        </td>
                                        <td>
                                            <%= comic.IssueNo %>
                                        </td>
                                        <td>
                                            <%= comic.Publisher || '-' %>
                                        </td>
                                        <td>
                                            <%= comic.PublishedYear || '-' %>
                                        </td>
                                        <td>
                                            <%= comic.Quantity %>
                                        </td>
                                        <td>
                                            <% if (user.IsAdmin) { %><a class="btn btn-sm btn-warning"
                                                    href="/editComic/<%= comic.ComicId %>">Edit</a> <a
                                                    class="btn btn-sm btn-danger"
                                                    href="/deleteComic/<%= comic.ComicId %>">Delete</a>
                                                <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
    </main>
</body>

</html>